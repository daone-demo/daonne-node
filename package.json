{
  "name": "daone-vercel-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/vercel-build.mjs",
    "build:dev": "DAONE_PROFILE=local node scripts/vercel-build.mjs",
    "build:test": "DAONE_PROFILE=test node scripts/vercel-build.mjs",
    "build:prod": "DAONE_PROFILE=prod node scripts/vercel-build.mjs",
    "config:local": "node scripts/config-check.mjs local",
    "config:test": "node scripts/config-check.mjs test",
    "config:prod": "node scripts/config-check.mjs prod",
    "db:sync": "node scripts/sync-runtime-store.mjs",
    "dev": "npx vercel dev",
    "start": "node scripts/local-server.mjs",
    "test": "node --test tests/*.test.mjs",
    "vercel-build": "node scripts/vercel-build-check.mjs"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "ioredis": "^5.11.1",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4"
  }
}

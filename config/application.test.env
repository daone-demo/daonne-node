# Test profile: Vercel Preview / test 分支部署使用。
DAONE_PROFILE=test
DAONE_FRONTEND_BASE_URL=https://dev.daoneai.com
DAONE_CORS_ALLOWED_ORIGINS=https://dev.daoneai.com,https://admin.daoneai.com,http://localhost:5173
DAONE_ADMIN_PHONES=
DAONE_TOKEN_TTL_SECONDS=604800
DAONE_SMS_CODE_TTL_SECONDS=300

DAONE_DB_TYPE=postgres

# Real database credentials must be configured in Vercel Environment Variables.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
POSTGRES_URL_NO_SSL=
POSTGRES_PRISMA_URL=

DAONE_AUTH_CACHE_TYPE=redis
REDIS_ENABLED=true
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

DAONE_SMS_MOCK_ENABLED=false
SMS_REGION_ID=cn-hangzhou
SMS_ENDPOINT=dysmsapi.aliyuncs.com
SMS_SIGN_NAME=
SMS_TEMPLATE_CODE=

